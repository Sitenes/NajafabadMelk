@model blogSingleViewModel
@{
ViewData["Title"] = "blog";
var httpContext = ViewContext?.HttpContext;
var lang = httpContext?.Items["lang"]?.ToString() ?? httpContext?.Request.RouteValues["lang"]?.ToString() ?? "en";
ViewData["Lang"] = lang;
var article = Model.article;
}

@if (article == null)
{
<section class="ftco-section">
<div class="container">
<div class="row justify-content-center">
<div class="col-md-8 text-center">
<h2>Article not found</h2>
</div>
</div>
</div>
</section>
}
else
{
<section class="hero-wrap  ftco-degree-bg js-fullheight" style="background-image: url('@Url.Content($"~/images/{article.ImageAddress()}")');"
 data-stellar-background-ratio="0.5">
<div class="overlay"></div>
<div class="container">
<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
<div class="col-md-9 ftco-animate pb-5 text-center">
<p class="breadcrumbs"><span class="mr-2"><a asp-controller="Home" asp-action="Index">Home <i
class="ion-ios-arrow-forward"></i></a></span> <span class="mr-2"><a
asp-controller="blog" asp-action="Index">Blog <i class="ion-ios-arrow-forward"></i></a></span> <span>Blog Single <i
class="ion-ios-arrow-forward"></i></span></p>
<h1 class="mb-3 bread">@article.LocalizedTitle(lang)</h1>
</div>
</div>
</div>
</section>

<section class="ftco-section ftco-degree-bg">
<div class="container">
<div class="row">
<div class="col-md-8 order-md-last ftco-animate">
<h2 class="mb-3">@article.LocalizedTitle(lang)</h2>
<div class="meta mb-3">
<div>@article.PublishedAt().ToString("yyyy/MM/dd")</div>
<div>@article.AuthorName()</div>
</div>
<p>@article.LocalizedDescription(lang)</p>
</div>
<div class="col-md-4 sidebar ftco-animate">
<div class="sidebar-box ftco-animate">
<h3>Recent Blog</h3>
@foreach (var recent in Model.recentArticles)
{
<div class="block-21 mb-4 d-flex">
<a class="blog-img mr-4" style="background-image: url('@Url.Content($"~/images/{recent.ImageAddress()}")');"></a>
<div class="text">
<h3 class="heading"><a asp-controller="blogSingle" asp-action="Index" asp-route-id="@recent.Id">@recent.LocalizedTitle(lang)</a></h3>
<div class="meta">
<div><a asp-controller="blogSingle" asp-action="Index" asp-route-id="@recent.Id"><span class="icon-calendar"></span> @recent.PublishedAt().ToString("yyyy/MM/dd")</a></div>
<div><a asp-controller="blogSingle" asp-action="Index" asp-route-id="@recent.Id"><span class="icon-person"></span> @recent.AuthorName()</a></div>
</div>
</div>
</div>
}
</div>
</div>
</div>
</div>
</section>
}
