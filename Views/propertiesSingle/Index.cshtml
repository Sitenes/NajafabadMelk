@using System.Linq
@model propertiesSingleViewModel
@{
	ViewData["Title"] = "Properties";
	var httpContext = ViewContext?.HttpContext;
	var lang = httpContext?.Items["lang"]?.ToString() ?? httpContext?.Request.RouteValues["lang"]?.ToString() ?? "en";
	string T(string en, string fa, string ar) => lang switch
	{
		"fa" => fa,
		"ar" => ar,
		_ => en
	};

	var advertisement = Model.advertisement;
	var house = advertisement?.House;
	var deal = advertisement?.Deal;
	var floors = house?.Floors ?? new List<Floor>();

	var title = lang switch
	{
		"fa" => advertisement?.TitleFa ?? advertisement?.TitleEn ?? advertisement?.TitleAr ?? string.Empty,
		"ar" => advertisement?.TitleAr ?? advertisement?.TitleEn ?? advertisement?.TitleFa ?? string.Empty,
		_ => advertisement?.TitleEn ?? advertisement?.TitleFa ?? advertisement?.TitleAr ?? string.Empty
	};

	var description = lang switch
	{
		"fa" => advertisement?.DescriptionFa ?? advertisement?.DescriptionEn ?? advertisement?.DescriptionAr ?? string.Empty,
		"ar" => advertisement?.DescriptionAr ?? advertisement?.DescriptionEn ?? advertisement?.DescriptionFa ?? string.Empty,
		_ => advertisement?.DescriptionEn ?? advertisement?.DescriptionFa ?? advertisement?.DescriptionAr ?? string.Empty
	};

	var amenities = lang switch
	{
		"fa" => house?.AmenitiesFa ?? house?.AmenitiesEn ?? house?.AmenitiesAr ?? string.Empty,
		"ar" => house?.AmenitiesAr ?? house?.AmenitiesEn ?? house?.AmenitiesFa ?? string.Empty,
		_ => house?.AmenitiesEn ?? house?.AmenitiesFa ?? house?.AmenitiesAr ?? string.Empty
	};

	var galleryImages = house?.Images?.Select(x => Url.Content($"~/images/{x.Url}")).ToList() ?? new List<string>();
	if (!galleryImages.Any())
	{
		galleryImages.Add(Url.Content("~/images/work-1.jpg"));
	}
	var mainImage = galleryImages.First();

	var hasOffer = deal?.HaveOffer == true && deal.FinalTotalPrice > 0;
	var totalPrice = deal?.TotalPrice ?? 0;
	var finalPrice = hasOffer ? deal?.FinalTotalPrice ?? totalPrice : totalPrice;
	var priceDiscountPercent = hasOffer && totalPrice > 0 && finalPrice < totalPrice
		? (int)Math.Round((1m - (finalPrice / totalPrice)) * 100m)
		: 0;

	var locationParts = new[] { house?.City, house?.District, house?.Neighborhood }
		.Where(x => !string.IsNullOrWhiteSpace(x))
		.ToList();
	var locationText = locationParts.Any() ? string.Join(" - ", locationParts) : T("Location not specified", "موقعیت ثبت نشده", "الموقع غير محدد");

	var totalArea = floors.Sum(x => x.Area);
	var totalRooms = floors.Sum(x => x.RoomCount);
	var toiletCount = floors.Sum(x => x.ToiletType?.Id == 1 || x.ToiletType?.Id == 2 ? 1 : 0);
	var totalCapacity = floors.Sum(x => x.Capacity);
	var areaValue = house?.BuildingArea ?? totalArea;

	ViewData["Lang"] = lang;
}

<section class="hero-wrap hero-wrap-2 ftco-degree-bg js-fullheight" style="background-image: url('@mainImage');" data-stellar-background-ratio="0.5">
	<div class="overlay"></div>
	<div class="container">
		<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
			<div class="col-md-9 ftco-animate pb-5 text-center">
				<p class="breadcrumbs">
					<span class="mr-2"><a asp-controller="Home" asp-action="Index">@T("Home", "خانه", "الرئيسية") <i class="ion-ios-arrow-forward"></i></a></span>
					<span>@T("Property", "ملک", "العقار") <i class="ion-ios-arrow-forward"></i></span>
				</p>
				<h1 class="mb-3 bread">@title</h1>
			</div>
		</div>
	</div>
</section>

<section class="ftco-section ftco-property-details" dir="ltr">
	<div class="container">
		<div class="row">
			<div class="col-lg-7 mb-4">
				<div class="bg-white p-3 shadow-sm" style="position: sticky; top: 110px;">
					<div class="mb-3">
						<img id="mainPropertyImage" src="@mainImage" alt="@title" style="width: 100%; height: 460px; object-fit: cover; border-radius: 8px;" />
					</div>
					<div class="row">
						@for (var i = 0; i < galleryImages.Count; i++)
						{
							var thumb = galleryImages[i];
							<div class="col-4 col-md-3 mb-3">
								<button type="button" class="property-thumb-btn" data-image="@thumb" style="display: block; width: 100%; border: 0; padding: 0; background: transparent; cursor: pointer;">
									<img src="@thumb" alt="thumb-@i" style="width: 100%; height: 95px; object-fit: cover; border-radius: 6px; border: 2px solid @(i == 0 ? "#e86ed0" : "#e6e6e6");" />
								</button>
							</div>
						}
					</div>
				</div>
			</div>

			<div class="col-lg-5 mb-4">
				<div class="bg-white p-4 shadow-sm mb-4">
					<h3 class="mb-2">@title</h3>
					<p class="text-muted mb-3">@locationText</p>
					<p class="h4 mb-0">@finalPrice.ToString("N0")</p>
					@if (hasOffer)
					{
						<p class="mb-2">
							<span class="text-muted" style="text-decoration: line-through;">@totalPrice.ToString("N0")</span>
							@if (priceDiscountPercent > 0)
							{
								<span class="badge badge-danger ml-2">@T("Discount", "تخفیف", "خصم") @priceDiscountPercent%</span>
							}
						</p>
					}

					<div class="table-responsive mt-3">
						<table class="table table-sm table-borderless mb-0">
							<tbody>
								<tr>
									<td><span class="flaticon-floor-plan mr-1"></span>@T("Total Area", "متراژ کل", "المساحة الكلية")</td>
									<td class="text-right">@areaValue.ToString("N0") sqft</td>
								</tr>
								<tr>
									<td><span class="flaticon-bed mr-1"></span>@T("Rooms", "اتاق", "الغرف")</td>
									<td class="text-right">@totalRooms</td>
								</tr>
								<tr>
									<td><span class="flaticon-bathtub mr-1"></span>@T("Bath Rooms", "حمام", "الحمامات")</td>
									<td class="text-right">@toiletCount</td>
								</tr>
								<tr>
									<td><span class="ion-ios-people mr-1"></span>@T("Capacity", "ظرفیت", "السعة")</td>
									<td class="text-right">@totalCapacity</td>
								</tr>
								<tr>
									<td><span class="ion-ios-pricetag mr-1"></span>@T("Property Code", "کد ملک", "رمز العقار")</td>
									<td class="text-right">@(string.IsNullOrWhiteSpace(house?.PropertyCode) ? "-" : house.PropertyCode)</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>

				<div class="bg-white p-4 shadow-sm mb-4">
					<h4 class="mb-3">@T("Financial", "مالی", "المالية")</h4>
					<div class="table-responsive">
						<table class="table table-sm table-borderless mb-0">
							<tbody>
								<tr>
									<td><span class="ion-ios-swap mr-1"></span>@T("Deal Type", "نوع معامله", "نوع الصفقة")</td>
									<td class="text-right">@(deal?.DealType?.Name ?? "-")</td>
								</tr>
								<tr>
									<td><span class="ion-logo-usd mr-1"></span>@T("Initial Price", "قیمت اولیه", "السعر الأساسي")</td>
									<td class="text-right">@totalPrice.ToString("N0")</td>
								</tr>
								<tr>
									<td><span class="ion-ios-cash mr-1"></span>@T("Final Price", "قیمت نهایی", "السعر النهائي")</td>
									<td class="text-right">@finalPrice.ToString("N0")</td>
								</tr>
								<tr>
									<td><span class="ion-ios-card mr-1"></span>@T("Down Payment", "پیش پرداخت", "الدفعة المقدمة")</td>
									<td class="text-right">@((deal?.DownPayment ?? 0).ToString("N0"))</td>
								</tr>
								<tr>
									<td><span class="ion-ios-calendar mr-1"></span>@T("Monthly Payment", "پرداخت ماهانه", "الدفع الشهري")</td>
									<td class="text-right">@((deal?.MonthlyPayment ?? 0).ToString("N0"))</td>
								</tr>
								<tr>
									<td><span class="ion-ios-pricetag mr-1"></span>@T("Offer Down Payment", "پیش پرداخت تخفیفی", "دفعة العرض")</td>
									<td class="text-right">@((deal?.FinalDownPayment ?? 0).ToString("N0"))</td>
								</tr>
								<tr>
									<td><span class="ion-ios-pricetags mr-1"></span>@T("Offer Monthly Payment", "قسط ماهانه تخفیفی", "قسط العرض الشهري")</td>
									<td class="text-right">@((deal?.FinalMonthlyPayment ?? 0).ToString("N0"))</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>

		<div class="row mt-2">
			<div class="col-md-12">
				<div class="bg-white p-4 shadow-sm">
					<h4 class="mb-3">@T("Description", "توضیحات", "الوصف")</h4>
					<p>@description</p>
					@if (!string.IsNullOrWhiteSpace(amenities))
					{
						<p class="mb-2"><strong>@T("Amenities", "امکانات", "المرافق"):</strong> @amenities</p>
					}
					@if (advertisement?.Keywords?.Any() == true)
					{
						<div>
							<strong>@T("Keywords", "کلمات کلیدی", "الكلمات المفتاحية"):</strong>
							@foreach (var keyword in advertisement.Keywords)
							{
								var tagText = lang switch
								{
									"fa" => keyword.ContentFa ?? keyword.ContentEn ?? keyword.ContentAr,
									"ar" => keyword.ContentAr ?? keyword.ContentEn ?? keyword.ContentFa,
									_ => keyword.ContentEn ?? keyword.ContentFa ?? keyword.ContentAr
								};
								if (!string.IsNullOrWhiteSpace(tagText))
								{
									<span class="badge mr-2" style="background-color: #d6eeff; color: #0b4d7a;">@tagText</span>
								}
							}
						</div>
					}
				</div>
			</div>
		</div>

		@if (floors.Any())
		{
			<div class="row mt-4">
				<div class="col-md-12">
					<div class="bg-white p-4 shadow-sm">
						<h4 class="mb-3">@T("Floor Details", "جزئیات هر طبقه", "تفاصيل كل طابق")</h4>
						<div class="row">
							@foreach (var floor in floors)
							{
								var floorMaterialsText = floor.FloorMaterials
									.Select(x => lang switch
									{
										"fa" => x.ContentFa ?? x.Name,
										"ar" => x.ContentAr ?? x.Name,
										_ => x.ContentEn ?? x.Name
									})
									.Where(x => !string.IsNullOrWhiteSpace(x))
									.Distinct()
									.ToList();

								<div class="col-md-6 mb-3">
									<div class="border rounded p-3 h-100">
										<h6 class="mb-3">@T("Floor", "طبقه", "الطابق") #@floor.Id</h6>
										<div class="table-responsive">
											<table class="table table-sm table-borderless mb-0">
												<tbody>
													<tr>
														<td>@T("Area", "متراژ", "المساحة")</td>
														<td class="text-right">@floor.Area.ToString("N0") sqft</td>
													</tr>
													<tr>
														<td>@T("Rooms", "اتاق", "الغرف")</td>
														<td class="text-right">@floor.RoomCount</td>
													</tr>
													<tr>
														<td>@T("Capacity", "ظرفیت", "السعة")</td>
														<td class="text-right">@floor.Capacity</td>
													</tr>
													<tr>
														<td>@T("Bathroom", "سرویس", "الحمام")</td>
														<td class="text-right">@(floor.ToiletType?.Value ?? 0)</td>
													</tr>
													<tr>
														<td>@T("Balcony", "بالکن", "الشرفة")</td>
														<td class="text-right">@(floor.HasBalcony ? (floor.BalconyArea?.ToString("N0") ?? "0") + " sqm" : "-")</td>
													</tr>
													<tr>
														<td>@T("Storage", "انباری", "التخزين")</td>
														<td class="text-right">@(floor.HasStorage ? (floor.StorageArea?.ToString("N0") ?? "0") + " sqm" : "-")</td>
													</tr>
													<tr>
														<td>@T("Direction", "جهت", "الاتجاه")</td>
														<td class="text-right">@(floor.ConstructionDirection ?? "-")</td>
													</tr>
													<tr>
														<td>@T("Cooling", "سرمایش", "التبريد")</td>
														<td class="text-right">@(floor.CoolingStatus ?? "-")</td>
													</tr>
													<tr>
														<td>@T("Heating", "گرمایش", "التدفئة")</td>
														<td class="text-right">@(floor.HeatingStatus ?? "-")</td>
													</tr>
													<tr>
														<td>@T("Hot Water", "آب گرم", "المياه الساخنة")</td>
														<td class="text-right">@(floor.HotWaterStatus ?? "-")</td>
													</tr>
													<tr>
														<td>@T("Materials", "متریال", "المواد")</td>
														<td class="text-right">@(floorMaterialsText.Any() ? string.Join(" - ", floorMaterialsText) : "-")</td>
													</tr>
												</tbody>
											</table>
										</div>
									</div>
								</div>
							}
						</div>
					</div>
				</div>
			</div>
		}

		@if (Model.relatedAdvertisements.Any())
		{
			<div class="row mt-5">
				<div class="col-md-12">
					<h4 class="mb-4">@T("Similar Properties", "املاک مشابه", "عقارات مشابهة")</h4>
				</div>
				@foreach (var item in Model.relatedAdvertisements)
				{
					var cardTitle = lang switch
					{
						"fa" => item.TitleFa ?? item.TitleEn ?? item.TitleAr ?? string.Empty,
						"ar" => item.TitleAr ?? item.TitleEn ?? item.TitleFa ?? string.Empty,
						_ => item.TitleEn ?? item.TitleFa ?? item.TitleAr ?? string.Empty
					};
					var cardImage = item.House?.Images?.FirstOrDefault()?.Url;
					var cardBackground = string.IsNullOrWhiteSpace(cardImage)
						? Url.Content("~/images/work-1.jpg")
						: Url.Content($"~/images/{cardImage}");
					<div class="col-md-4">
						<div class="property-wrap ftco-animate">
							<a asp-controller="propertiesSingle" asp-action="Index" asp-route-id="@item.Id" class="img" style="background-image: url('@cardBackground');"></a>
							<div class="text">
								<p class="price"><span class="orig-price">@item.Deal?.FinalTotalPrice.ToString("N0")</span></p>
								<h3><a asp-controller="propertiesSingle" asp-action="Index" asp-route-id="@item.Id">@cardTitle</a></h3>
							</div>
						</div>
					</div>
				}
			</div>
		}
	</div>
</section>

<script>
	document.addEventListener("DOMContentLoaded", function () {
		var mainImage = document.getElementById("mainPropertyImage");
		var thumbs = document.querySelectorAll(".property-thumb-btn");

		thumbs.forEach(function (btn) {
			btn.addEventListener("click", function () {
				var src = btn.getAttribute("data-image");
				if (!src || !mainImage) {
					return;
				}

				mainImage.setAttribute("src", src);
				thumbs.forEach(function (otherBtn) {
					var img = otherBtn.querySelector("img");
					if (img) {
						img.style.border = "2px solid #e6e6e6";
					}
				});

				var selectedImg = btn.querySelector("img");
				if (selectedImg) {
					selectedImg.style.border = "2px solid #e86ed0";
				}
			});
		});
	});
</script>