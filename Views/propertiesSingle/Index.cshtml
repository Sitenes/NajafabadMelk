@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model propertiesSingleViewModel
@{
	ViewData["Title"] = "Properties";
	var httpContext = ViewContext?.HttpContext;
	var lang = httpContext?.Items["lang"]?.ToString() ?? httpContext?.Request.RouteValues["lang"]?.ToString() ?? "en";
	var advertisement = Model.advertisement;
	var house = advertisement?.House;
	var floors = house?.Floors ?? new List<Floor>();
	var firstFloor = floors.FirstOrDefault();
	var imageUrl = house?.Images?.FirstOrDefault()?.Url;
	var backgroundImage = string.IsNullOrWhiteSpace(imageUrl)
		? Url.Content("~/images/work-1.jpg")
		: Url.Content($"~/images/{imageUrl}");
	var title = lang switch
	{
		"fa" => advertisement?.TitleFa ?? advertisement?.TitleEn ?? advertisement?.TitleAr ?? string.Empty,
		"ar" => advertisement?.TitleAr ?? advertisement?.TitleEn ?? advertisement?.TitleFa ?? string.Empty,
		_ => advertisement?.TitleEn ?? advertisement?.TitleFa ?? advertisement?.TitleAr ?? string.Empty
	};
	var description = lang switch
	{
		"fa" => advertisement?.DescriptionFa ?? advertisement?.DescriptionEn ?? advertisement?.DescriptionAr ?? string.Empty,
		"ar" => advertisement?.DescriptionAr ?? advertisement?.DescriptionEn ?? advertisement?.DescriptionFa ?? string.Empty,
		_ => advertisement?.DescriptionEn ?? advertisement?.DescriptionFa ?? advertisement?.DescriptionAr ?? string.Empty
	};
	var toiletCount = floors.Sum(x => x.ToiletType?.Id == 1 ? 1 : 0);
	ViewData["Lang"] = lang;
}

<section class="hero-wrap  ftco-degree-bg js-fullheight" style="background-image: url('images/bg_1.jpg');"
		 data-stellar-background-ratio="0.5">
	<div class="overlay"></div>
	<div class="container">
		<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
			<div class="col-md-9 ftco-animate pb-5 text-center">
				<p class="breadcrumbs"><span class="mr-2"><a href="index.html">Home <i
					class="ion-ios-arrow-forward"></i></a></span> <span>Properties <i
					class="ion-ios-arrow-forward"></i></span></p>
					<h1 class="mb-3 bread">@title</h1>
				</div>
			</div>
		</div>
	</section>

	<section class="ftco-section ftco-property-details">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-12">
					<div class="property-details">
						<div class="img" style="background-image: url(@backgroundImage);"></div>
						<div class="text text-center">
							<span class="subheading">@(advertisement?.Deal?.FinalTotalPrice.ToString("N0") ?? "0")</span>
							<h2>@title</h2>
						</div>
					</div>
				</div>
			</div>
			<div class="row">
				<div class="col-md-12 pills">
					<div class="bd-example bd-example-tabs">
						<div class="d-flex justify-content-center">
							<ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">

								<li class="nav-item">
									<a class="nav-link active" id="pills-description-tab" data-toggle="pill"
									   href="#pills-description" role="tab" aria-controls="pills-description"
									   aria-expanded="true">Features</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" id="pills-manufacturer-tab" data-toggle="pill"
									   href="#pills-manufacturer" role="tab" aria-controls="pills-manufacturer"
									   aria-expanded="true">Description</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" id="pills-review-tab" data-toggle="pill" href="#pills-review"
									   role="tab" aria-controls="pills-review" aria-expanded="true">Review</a>
								</li>
							</ul>
						</div>

						<div class="tab-content" id="pills-tabContent">
							<div class="tab-pane fade show active" id="pills-description" role="tabpanel"
								 aria-labelledby="pills-description-tab">
								<div class="row">
									<div class="col-md-4">
										<ul class="features">
											<li class="check"><span class="ion-ios-checkmark"></span>Total Area: @floors.Sum(x => x.Area).ToString("N0") sqft</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Bed Rooms: @floors.Sum(x => x.RoomCount)</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Bath Rooms: @toiletCount</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Floors: @(house?.FloorCount ?? 0)</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Parking: @(house?.HasParking == true ? (house.ParkingCount ?? 1) : 0)</li>
										</ul>
									</div>
									<div class="col-md-4">
										<ul class="features">
											<li class="check"><span class="ion-ios-checkmark"></span>Floor Area: @((firstFloor?.Area ?? 0).ToString("N0")) sqft</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Construction: @(house?.ConstructionTime.ToString("yyyy") ?? "-")</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Direction: @(firstFloor?.ConstructionDirection ?? "-")</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Cooling: @(firstFloor?.CoolingStatus ?? "-")</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Heating: @(firstFloor?.HeatingStatus ?? "-")</li>
										</ul>
									</div>
									<div class="col-md-4">
										<ul class="features">
											<li class="check"><span class="ion-ios-checkmark"></span>Deal Type: @(advertisement?.Deal?.DealType?.Name ?? "-")</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Total Price: @(advertisement?.Deal?.TotalPrice.ToString("N0") ?? "0")</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Offer Price: @(advertisement?.Deal?.FinalTotalPrice.ToString("N0") ?? "0")</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Balcony Area: @floors.Sum(x => x.BalconyArea ?? 0).ToString("N0") sqm</li>
											<li class="check"><span class="ion-ios-checkmark"></span>Registered: @(house?.RegistrationTime.ToString("yyyy/MM/dd") ?? "-")</li>
										</ul>
									</div>
								</div>
							</div>

							<div class="tab-pane fade" id="pills-manufacturer" role="tabpanel"
								 aria-labelledby="pills-manufacturer-tab">
								<p>@description</p>
									</div>

