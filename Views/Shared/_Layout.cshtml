<body>
    @{
        // دریافت مسیر فعلی مثلاً /en/about
        var currentPath = ViewContext.HttpContext.Request.Path.Value ?? "/";

        // تابعی کوچک برای ساخت لینک جدید
        string GetLocalizedUrl(string lang)
        {
            // جدا کردن بخش‌های مسیر (مثلا: ["", "en", "about"])
            var segments = currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);

            // اگر آدرس فعلی ریشه باشد (فقط /)
            if (segments.Length == 0) return $"/{lang}";

            // چک کردن اینکه آیا بخش اول مسیر یک کد زبان است (مثلا fa, en, ar)
            var supportedLanguages = new[] { "fa", "en", "ar" };
            if (supportedLanguages.Contains(segments[0]))
            {
                // جایگزینی زبان فعلی با زبان جدید
                segments[0] = lang;
            }
            else
            {
                // اگر در آدرس زبان وجود ندارد، آن را به اول اضافه می‌کنیم
                var newSegments = new string[segments.Length + 1];
                newSegments[0] = lang;
                Array.Copy(segments, 0, newSegments, 1, segments.Length);
                segments = newSegments;
            }

            return "/" + string.Join("/", segments);
        }
    }
