	ViewData["Title"] = "about";
	var httpContext = ViewContext?.HttpContext;
	var lang = httpContext?.Items["lang"]?.ToString() ?? httpContext?.Request.RouteValues["lang"]?.ToString() ?? "en";
	ViewData["Lang"] = lang;
}

