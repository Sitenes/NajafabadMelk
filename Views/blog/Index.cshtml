@model blogViewModel
@{
ViewData["Title"] = "blog";
var httpContext = ViewContext?.HttpContext;
var lang = httpContext?.Items["lang"]?.ToString() ?? httpContext?.Request.RouteValues["lang"]?.ToString() ?? "en";
ViewData["Lang"] = lang;
}

<section class="hero-wrap  ftco-degree-bg js-fullheight" style="background-image: url('images/bg_1.jpg');"
 data-stellar-background-ratio="0.5">
<div class="overlay"></div>
<div class="container">
<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
<div class="col-md-9 ftco-animate pb-5 text-center">
<p class="breadcrumbs"><span class="mr-2"><a asp-controller="Home" asp-action="Index">Home <i
class="ion-ios-arrow-forward"></i></a></span> <span>Blog <i
class="ion-ios-arrow-forward"></i></span></p>
<h1 class="mb-3 bread">Our Blog</h1>
</div>
</div>
</div>
</section>

<section class="ftco-section">
<div class="container">
<div class="row d-flex">
@foreach (var article in Model.articles)
{
<div class="col-md-3 d-flex ftco-animate">
<div class="blog-entry justify-content-end">
<div class="text">
<h3 class="heading"><a asp-controller="blogSingle" asp-action="Index" asp-route-id="@article.Id">@article.LocalizedTitle(lang)</a></h3>
<div class="meta mb-3">
<div><a asp-controller="blogSingle" asp-action="Index" asp-route-id="@article.Id">@article.PublishedAt().ToString("yyyy/MM/dd")</a></div>
<div><a asp-controller="blogSingle" asp-action="Index" asp-route-id="@article.Id">@article.AuthorName()</a></div>
</div>
<a asp-controller="blogSingle" asp-action="Index" asp-route-id="@article.Id" class="block-20 img"
   style="background-image: url('@Url.Content($"~/images/{article.ImageAddress()}")');">
</a>
<p>@article.LocalizedSummary(lang)</p>
</div>
</div>
</div>
}
</div>
@{
var totalPages = Model.TotalPages;
}
<div class="row mt-5">
<div class="col text-center">
@if (totalPages > 1)
{
<div class="block-27">
<ul>
<li class="@(Model.CurrentPage <= 1 ? "disabled" : null)">
<a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">&lt;</a>
</li>
@for (var pageNumber = 1; pageNumber <= totalPages; pageNumber++)
{
<li class="@(pageNumber == Model.CurrentPage ? "active" : null)">
@if (pageNumber == Model.CurrentPage)
{
<span>@pageNumber</span>
}
else
{
<a asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
}
</li>
}
<li class="@(Model.CurrentPage >= totalPages ? "disabled" : null)">
<a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">&gt;</a>
</li>
</ul>
</div>
}
</div>
</div>
</div>
</section>
